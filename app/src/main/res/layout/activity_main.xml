<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0C10"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layoutDirection="rtl">

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⚡ ZOVEX INJECTOR"
            android:textColor="#00F5C4" android:textSize="18sp" android:textStyle="bold"
            android:fontFamily="monospace" android:gravity="center"
            android:paddingTop="20dp" android:paddingBottom="4dp"/>

        <View android:layout_width="60dp" android:layout_height="2dp"
            android:layout_gravity="center" android:background="#00F5C4"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="APK Dialog Injection Tool"
            android:textColor="#4A5568" android:textSize="11sp"
            android:fontFamily="monospace" android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📦  קובץ APK" android:textColor="#4A5568"
            android:textSize="11sp" android:fontFamily="monospace"
            android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnPickApk"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:background="@drawable/bg_card"
            android:text="לחץ לבחירת קובץ APK"
            android:textColor="#718096" android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/rowApkInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp" android:visibility="gone">
            <TextView android:id="@+id/tvApkName"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:textColor="#E2E8F0" android:textSize="13sp"
                android:singleLine="true" android:ellipsize="middle"/>
            <TextView android:id="@+id/tvApkSize"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#00F5C4" android:textSize="11sp"
                android:fontFamily="monospace" android:background="#00F5C415"
                android:paddingHorizontal="8dp" android:paddingVertical="3dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙️  הגדרות הדיאלוג" android:textColor="#4A5568"
            android:textSize="11sp" android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="כותרת *" android:textColor="#A0AEC0" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/etTitle"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:textColor="#E2E8F0" android:textColorHint="#4A5568"
                android:hint="עדכון חשוב" android:textSize="13sp"
                android:gravity="right" android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="הודעה *" android:textColor="#A0AEC0" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/etDescription"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:textColor="#E2E8F0" android:textColorHint="#4A5568"
                android:hint="הכנס את תוכן ההודעה..." android:textSize="13sp"
                android:gravity="right|top" android:inputType="textMultiLine"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="טקסט כפתור אישור" android:textColor="#A0AEC0" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/etOkText"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:textColor="#E2E8F0" android:textColorHint="#4A5568"
                android:hint="אישור" android:textSize="13sp"
                android:gravity="right" android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="קישור טלגרם / ווטסאפ" android:textColor="#A0AEC0" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="אופציונלי" android:textColor="#4A5568" android:textSize="10sp"/>
            </LinearLayout>
            <EditText android:id="@+id/etTelegramUrl"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:textColor="#E2E8F0" android:textColorHint="#4A5568"
                android:hint="https://t.me/mychannel" android:textSize="12sp"
                android:gravity="right" android:inputType="textUri"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="מזהה ייחודי (Pref Key)" android:textColor="#A0AEC0" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/etPrefKey"
                android:layout_width="match_parent" android:layout_height="46dp"
                android:background="@drawable/bg_field" android:padding="10dp"
                android:textColor="#E2E8F0" android:textColorHint="#4A5568"
                android:hint="my_dialog_v1" android:textSize="12sp"
                android:gravity="right" android:inputType="text"
                android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="שנה מספר בין גרסאות כדי להציג שוב"
                android:textColor="#4A5568" android:textSize="11sp"/>
        </LinearLayout>

        <Button android:id="@+id/btnInject"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/bg_btn_primary"
            android:text="⚡  הזרק דיאלוג"
            android:textColor="#00F5C4" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnDeleteDialogs"
            android:layout_width="match_parent" android:layout_height="46dp"
            android:background="@drawable/bg_btn_danger"
            android:text="🗑️  מחק דיאלוגים קיימים"
            android:textColor="#FF4D6D" android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:id="@+id/sectionProgress"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ProgressBar android:id="@+id/progressBar"
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:indeterminate="true" android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/tvStep"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="מעבד..." android:textColor="#E2E8F0" android:textSize="13sp"/>
            </LinearLayout>
            <TextView android:id="@+id/tvLog"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#4A5568" android:textSize="11sp"
                android:fontFamily="monospace" android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/sectionResult"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅ הסתיים!" android:textColor="#00F5C4"
                android:textSize="15sp" android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvResultInfo"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#718096" android:textSize="12sp"
                android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#FF4D6D0F"
                android:paddingHorizontal="12dp" android:paddingVertical="10dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚠️  החתימה השתנתה — הסר את האפליקציה הישנה לפני התקנה"
                    android:textColor="#FF6B83" android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
            <Button android:id="@+id/btnInstall"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="📲  התקן APK עכשיו"
                android:textColor="#00F5C4" android:textSize="14sp" android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <Button android:id="@+id/btnShare"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/bg_card"
                android:text="📤  שתף / שמור APK"
                android:textColor="#718096" android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/sectionError"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#FF4D6D0F"
            android:paddingHorizontal="16dp" android:paddingVertical="12dp"
            android:layout_marginBottom="12dp" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="❌ שגיאה" android:textColor="#FF4D6D"
                android:textSize="13sp" android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvError"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FF6B83" android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="32dp"/>
    </LinearLayout>
</ScrollView>
